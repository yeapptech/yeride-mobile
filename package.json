{
  "name": "yeride-next",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean && node scripts/patch-podfile.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@googlemaps/react-native-navigation-sdk": "^0.14.1",
    "@gorhom/bottom-sheet": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@react-native-firebase/functions": "^24.0.0",
    "@react-native-firebase/storage": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@stripe/stripe-react-native": "0.63.0",
    "@tanstack/react-query": "^5.100.5",
    "expo": "~55.0.17",
    "expo-build-properties": "~55.0.7",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.10",
    "expo-file-system": "~55.0.17",
    "expo-image-picker": "~55.0.19",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.22",
    "expo-print": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.6",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.83.6",
    "react-native-background-geolocation": "^5.1.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-places-autocomplete": "2.6.4",
    "react-native-maps": "^1.24.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "0.7.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
