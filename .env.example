# YeRide Next environment template.
#
# Copy to .env.development / .env.stage / .env.production as needed.
# Each phase appends new keys. Values that are truly secret (Stripe restricted
# keys, Firebase service-account creds) MUST live in EAS Secrets, never here.

# ───── Phase 0 ─────
# Selects the build flavor — one of: development, stage, production.
EXPO_PUBLIC_APP_ENV=development

# ───── Phase 2 turn 2 — Google Maps Platform ─────
# Routes API + Maps SDK keys. Platform-specific because Google's native Maps
# SDKs (used by react-native-maps) require a per-platform key. The same key
# is used for the Routes API HTTPS calls.
#
# NOT prefixed with EXPO_PUBLIC_ on purpose: keys flow through `app.config.ts`
# `extra` and are read at runtime via expo-constants. This keeps them out of
# the JS bundle string blob and matches legacy yeride naming.
GOOGLE_MAPS_APIKEY_ANDROID=
GOOGLE_MAPS_APIKEY_IOS=

# ───── Phase 7 — react-native-background-geolocation ─────
# The Transistor Software SDK is license-keyed for production builds. The key
# is consumed at BUILD time by the SDK's Expo plugin block (in app.config.ts)
# and baked into the native bundle — there is NO runtime read. Without this
# set, the SDK runs in time-limited debug mode: fine for short dev sessions,
# blocks release builds. Lift the value verbatim from the legacy yeride .env.
BG_GEOLOCATION_LICENSE_KEY=
