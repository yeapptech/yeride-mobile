# YeRide Next environment template.
#
# Copy to .env.development / .env.stage / .env.production as needed.
# Each phase appends new keys. Values that are truly secret (Stripe restricted
# keys, Firebase service-account creds) MUST live in EAS Secrets, never here.

# ───── Phase 0 ─────
# Selects the build flavor — one of: development, stage, production.
EXPO_PUBLIC_APP_ENV=development
